---
/**
 * /series — Browse all blog series (folders).
 *
 * Dynamically detects every multi-part series by scanning for posts whose
 * `id` contains a `/` (i.e. lives inside a subfolder). Groups them by
 * folder, picks the index post's metadata as the series title/description.
 */
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog', ({ data }) => !data.draft)

const folderMap = new Map<string, typeof allPosts>()
for (const post of allPosts) {
  const slashIndex = post.id.indexOf('/')
  if (slashIndex === -1) continue
  const folder = post.id.substring(0, slashIndex)
  const existing = folderMap.get(folder) ?? []
  existing.push(post)
  folderMap.set(folder, existing)
}

const series = [...folderMap.entries()].map(([folder, posts]) => {
  const indexPost = posts.find((p) => p.id === `${folder}/index`)
  const rep = indexPost ?? posts[0]
  const parts = posts.filter((p) => p.id !== `${folder}/index`)
  const latest = posts.reduce(
    (max, p) => (p.data.pubDate > max ? p.data.pubDate : max),
    posts[0].data.pubDate,
  )
  return {
    slug: folder,
    title: rep.data.title,
    description: rep.data.description,
    category: rep.data.category,
    postCount: parts.length,
    latestDate: latest,
  }
})
series.sort((a, b) => b.latestDate.valueOf() - a.latestDate.valueOf())
---

<BaseLayout title="Series — Blog" description="Browse multi-part blog series.">
  <div class="page">
    <header class="page-head">
      <h1>Series</h1>
      <p class="meta">{series.length} series — {series.reduce((sum, s) => sum + s.postCount, 0)} posts.</p>
    </header>

    <ul class="series-grid">
      {series.map((s) => (
        <li>
          <a class="series-card" href={`/series/${s.slug}/`}>
            <span class="series-cat">{s.category}</span>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <span class="series-meta">{s.postCount} part{s.postCount !== 1 ? 's' : ''}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { padding-block: 2.5rem 4rem; }
  .page-head { margin-bottom: 1.5rem; }
  h1 { font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-muted); font-size: 0.9375rem; margin: 0.5rem 0 0; }
  .series-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .series-card {
    display: grid; gap: 0.5rem;
    padding: 1.125rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-fg);
    text-decoration: none;
  }
  .series-card:hover { border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); }
  .series-cat {
    align-self: start;
    padding: 0.125rem 0.5rem;
    background: var(--color-bg-muted);
    border-radius: 0.25rem;
    color: var(--color-fg-muted);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .series-card h3 { margin: 0; font-size: 1.0625rem; font-weight: 600; line-height: 1.35; }
  .series-card p { margin: 0; color: var(--color-fg-muted); font-size: 0.9375rem; }
  .series-meta { color: var(--color-fg-soft); font-size: 0.8125rem; }
</style>
