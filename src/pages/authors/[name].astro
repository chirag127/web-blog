---
/**
 * /authors/[name] — every post by a single author.
 */
import type { GetStaticPaths } from 'astro'
import { getAuthorsWithCounts, getPostsByAuthor, slugifyTag } from '~/lib/blog'
import { SITE_CONFIG } from '~/lib/config'

export const getStaticPaths = (async () => {
  const authors = await getAuthorsWithCounts()
  return Promise.all(
    authors.map(async ({ author }) => ({
      params: { name: slugifyTag(author) },
      props: { author, posts: await getPostsByAuthor(author) },
    })),
  )
}) satisfies GetStaticPaths

const { author, posts } = Astro.props as {
  author: string
  posts: Awaited<ReturnType<typeof getPostsByAuthor>>
}

const _title = `Posts by ${author}`
const _description = `${posts.length} ${posts.length === 1 ? 'post' : 'posts'} by ${author} on blog.oriz.in.`

const _jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: { '@type': 'Person', name: author },
  url: new URL(Astro.url.pathname, SITE_CONFIG.url).toString(),
}
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/authors/">All authors</a>
    </nav>
    <header class="page-head">
      <h1>{author}</h1>
      <p class="meta">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
    </header>

    <ul class="post-grid">
      {posts.map((p) => (
        <li><PostCard post={p} /></li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { padding-block: 2.5rem 4rem; }
  .crumbs { color: var(--color-fg-soft); font-size: 0.8125rem; margin-bottom: 0.75rem; }
  .crumbs a { color: var(--color-fg-muted); text-decoration: none; }
  .crumbs a:hover { color: var(--color-fg); text-decoration: underline; }
  .page-head { margin-bottom: 1.5rem; }
  h1 { font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-muted); font-size: 0.9375rem; margin: 0.5rem 0 0; }
  .post-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
