---
/**
 * /authors — list every distinct author across the blog with a count.
 * Almost everything on this blog is by Chirag, but the schema permits
 * other authors and the route honors them.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getAuthorsWithCounts, slugifyTag } from '~/lib/blog'
import { SITE_CONFIG } from '~/lib/config'

const authors = await getAuthorsWithCounts()

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Authors',
  url: new URL('/authors/', SITE_CONFIG.url).toString(),
  description: 'Authors who have written for blog.oriz.in.',
}
---

<BaseLayout title="Authors — Blog" description="Browse posts by author." jsonLd={jsonLd}>
  <div class="page">
    <header class="page-head">
      <h1>Authors</h1>
      <p class="meta">{authors.length} author{authors.length !== 1 ? 's' : ''}.</p>
    </header>

    <ul class="author-grid">
      {authors.map(({ author, count }) => (
        <li>
          <a class="author-card" href={`/authors/${slugifyTag(author)}/`}>
            <span class="author-mark" aria-hidden="true">{author.charAt(0)}</span>
            <span class="author-text">
              <strong>{author}</strong>
              <span class="author-count">{count} post{count !== 1 ? 's' : ''}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { padding-block: 2.5rem 4rem; }
  .page-head { margin-bottom: 1.5rem; }
  h1 { font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-muted); font-size: 0.9375rem; margin: 0.5rem 0 0; }
  .author-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 0.625rem;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }
  .author-card {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 0.875rem 1.125rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-fg);
    text-decoration: none;
  }
  .author-card:hover { border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); }
  .author-mark {
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-radius: 999px;
    font-family: var(--font-serif);
    font-weight: 600;
  }
  .author-text { display: flex; flex-direction: column; gap: 0.125rem; }
  .author-count { color: var(--color-fg-muted); font-size: 0.8125rem; }
</style>
