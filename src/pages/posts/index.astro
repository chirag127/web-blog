---
/**
 * /posts — paginated, date-sorted index of the new `posts` collection.
 *
 * Coexists with /blog/ (legacy bulk-import collection). The `posts`
 * collection is where new spec-conformant entries land; this page
 * lists them with the same chrome as /blog/ but with the family-wide
 * Algolia <Search /> island bolted on top.
 */
import { getCollection } from 'astro:content'

const all = await getCollection('posts', ({ data }) => data.draft === false).catch(() => [])
const sorted = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const _fallback = sorted.map((p) => ({
  objectID: p.id,
  title: p.data.title,
  description: p.data.description,
  url: `/posts/${p.id}/`,
  pubDate: p.data.pubDate.toISOString(),
  tags: p.data.tags,
}))

const _fmt = (d: Date): string =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })
---

<BaseLayout
  title="Posts — oriz / blog"
  description="Long-form writing on engineering, finance, and books — sorted by date."
>
  <FeedDiscovery slot="head" />
  <section class="posts-index">
    <header class="posts-head">
      <h1>Posts</h1>
      <p class="posts-dek">
        {sorted.length} {sorted.length === 1 ? 'post' : 'posts'}, newest first.
        Subscribe via <a href="/rss.xml">RSS</a>, <a href="/atom.xml">Atom</a>,
        or <a href="/feed.json">JSON Feed</a>.
      </p>
      <div class="posts-search">
        <Search client:idle fallback={fallback} placeholder="Search posts…" />
      </div>
    </header>

    <ol class="posts-list">
      {sorted.map((post) => (
        <li class="posts-item">
          <a href={`/posts/${post.id}/`} class="posts-link">
            <time datetime={post.data.pubDate.toISOString()} class="posts-date">
              {fmt(post.data.pubDate)}
            </time>
            <h2 class="posts-title">{post.data.title}</h2>
            <p class="posts-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <ul class="posts-tags" aria-label="Tags">
                {post.data.tags.map((t) => <li>#{t}</li>)}
              </ul>
            )}
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .posts-index {
    max-width: 66ch;
    margin-inline: auto;
    padding-block: 2.5rem 4rem;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }
  .posts-head { margin-bottom: 2rem; }
  .posts-head h1 {
    font-family: var(--font-display, serif);
    font-size: clamp(2rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }
  .posts-dek { color: var(--ink-mute, #666); margin: 0 0 1.5rem; }
  .posts-search { margin-block: 1.5rem; }
  .posts-list { list-style: none; padding: 0; margin: 0; }
  .posts-item + .posts-item { margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--rule, #eee); }
  .posts-link { display: block; text-decoration: none; color: inherit; }
  .posts-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-mute, #666);
  }
  .posts-title {
    font-family: var(--font-display, serif);
    font-size: 1.5rem;
    margin: 0.25rem 0 0.5rem;
    color: var(--ink, #111);
  }
  .posts-link:hover .posts-title { color: var(--cobalt, #1f4ed8); }
  .posts-desc { margin: 0; color: var(--ink-mute, #555); }
  .posts-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; list-style: none; padding: 0; margin: 0.625rem 0 0; }
  .posts-tags li {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--ink-mute, #888);
  }
</style>
