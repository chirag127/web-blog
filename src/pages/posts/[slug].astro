---
/**
 * /posts/[slug] — single post page for the `posts` collection.
 *
 * Renders an Article + BreadcrumbList JSON-LD pair, mounts Giscus
 * with a consent gate at the bottom, and exposes the post body to
 * Pagefind for the family-wide MultiSearch.
 */
import type { GetStaticPaths } from 'astro'
import { type CollectionEntry, getCollection, render } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import GiscusComments from '~/components/blog/GiscusComments.astro'
import { SITE_CONFIG } from '~/lib/config'

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts', ({ data }) => data.draft === false).catch(() => [])
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}) satisfies GetStaticPaths

interface PageProps {
  post: CollectionEntry<'posts'>
}
const { post } = Astro.props as PageProps
const { Content } = await render(post)

const url = new URL(`/posts/${post.id}/`, SITE_CONFIG.url).toString()
const datePublished = post.data.pubDate.toISOString()
const dateModified = (post.data.updatedDate ?? post.data.pubDate).toISOString()
const canonical = post.data.canonicalUrl ?? url

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished,
  dateModified,
  author: { '@type': 'Person', name: post.data.author, url: SITE_CONFIG.author.url },
  publisher: { '@type': 'Person', name: SITE_CONFIG.author.name, url: SITE_CONFIG.author.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
  inLanguage: SITE_CONFIG.defaultLocale,
  image: post.data.heroImage
    ? new URL(post.data.heroImage, SITE_CONFIG.url).toString()
    : undefined,
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Posts', item: `${SITE_CONFIG.url}/posts/` },
    { '@type': 'ListItem', position: 2, name: post.data.title, item: url },
  ],
}

const fmt = (d: Date): string =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout
  title={`${post.data.title} — oriz / blog`}
  description={post.data.description}
  type="article"
  canonical={canonical}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  image={post.data.heroImage}
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <article class="post" data-pagefind-body>
    <header class="post-head">
      <p class="post-meta">
        <time datetime={datePublished}>{fmt(post.data.pubDate)}</time>
        <span aria-hidden="true"> · </span>
        <span>By {post.data.author}</span>
      </p>
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="post-dek">{post.data.description}</p>}
    </header>
    <div class="post-body prose-blog">
      <Content />
    </div>
    {post.data.tags.length > 0 && (
      <ul class="post-tags" aria-label="Tags">
        {post.data.tags.map((t) => <li>#{t}</li>)}
      </ul>
    )}
    <hr />
    <GiscusComments />
  </article>
</BaseLayout>

<style>
  .post { max-width: 66ch; margin-inline: auto; padding: 2.5rem clamp(1rem, 4vw, 2rem) 4rem; }
  .post-head { margin-bottom: 2rem; }
  .post-meta {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--ink-mute, #666);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem;
  }
  .post h1 {
    font-family: var(--font-display, serif);
    font-size: clamp(2rem, 4.6vw, 2.625rem);
    line-height: 1.1;
    margin: 0 0 0.75rem;
  }
  .post-dek { font-style: italic; color: var(--ink-mute, #666); margin: 0; }
  .post-body { margin-top: 1.5rem; }
  .post-tags { display: flex; gap: 0.5rem; list-style: none; padding: 0; margin: 2rem 0 0; flex-wrap: wrap; }
  .post-tags li {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--ink-mute, #888);
  }
  hr { margin: 3rem 0; border: 0; border-top: 1px solid var(--rule, #eee); }
</style>
