---
const _web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — oriz / blog"
  description="Get in touch about anything on blog.oriz.in."
>
  <header class="page-head">
    <p class="eyebrow"><a href="/">Blog</a> / Contact</p>
    <h1>Contact</h1>
  </header>

  <section class="prose">
    <p class="lede">
      The fastest way to reach me about a blog post — typo, broken link,
      follow-up question, or pitch — is email:
      <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
    </p>
    <p>
      Or use the form below — it posts to Web3Forms which forwards to my inbox.
      No data is stored on this site.
    </p>

    <ContactForm
      client:load
      web3formsKey={web3formsKey}
      fromName="blog.oriz.in contact form"
    />

    <p>
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
    </p>
  </section>
</BaseLayout>
