---
import {
  getCategoriesWithCounts,
  getPostsInSeries,
  getPublishedPosts,
  getSeriesWithCounts,
  slugifyTag,
} from '~/lib/blog'
import { SITE_CONFIG } from '~/lib/config'

const allPosts = await getPublishedPosts()
const _recentPosts = allPosts.slice(0, 8)

const seriesAll = await getSeriesWithCounts()
// In-progress: series where at least one post exists. We model "published"
// as the count of currently-published parts. Total is exposed as a heuristic
// (count + a small tail of "drafting" dots) — for v1 of the v2 design, we
// just use count for total and count for published, and animate the last
// dot as `current` so the spine has the signature glyph (`⦿`) visible.
type InProgress = {
  name: string
  slug: string
  total: number
  published: number
  current: number
  latest: Date
  parts: Awaited<ReturnType<typeof getPostsInSeries>>
}
const inProgress: InProgress[] = []
for (const { series, count } of seriesAll.slice(0, 4)) {
  const parts = await getPostsInSeries(series)
  const latest = parts.reduce(
    (max, p) => (p.data.pubDate > max ? p.data.pubDate : max),
    parts[0].data.pubDate,
  )
  // Heuristic: if every part declares a `part` field with the largest
  // explicit value, use that as the total; otherwise pad by 2 to suggest
  // upcoming parts. Capped at 12 dots so the spine fits on one row.
  const explicitMax = parts.reduce((mx, p) => {
    const v = typeof p.data.part === 'number' ? p.data.part : Number(p.data.part)
    return Number.isFinite(v) ? Math.max(mx, v) : mx
  }, 0)
  const total = Math.min(12, Math.max(count + (explicitMax > count ? 0 : 2), explicitMax))
  inProgress.push({
    name: series,
    slug: slugifyTag(series),
    total,
    published: count,
    current: count, // last filled dot is "current"
    latest,
    parts,
  })
}
inProgress.sort((a, b) => b.latest.valueOf() - a.latest.valueOf())

const _cats = await getCategoriesWithCounts()

// "Days since" helper for the in-progress rail.
function _ago(date: Date): string {
  const days = Math.floor((Date.now() - date.valueOf()) / 86_400_000)
  if (days < 1) return 'today'
  if (days === 1) return '1d ago'
  if (days < 30) return `${days}d ago`
  const months = Math.floor(days / 30)
  if (months === 1) return '1mo ago'
  if (months < 12) return `${months}mo ago`
  const years = Math.floor(days / 365)
  return years === 1 ? '1y ago' : `${years}y ago`
}

const _jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: SITE_CONFIG.title,
  url: `${SITE_CONFIG.url}/`,
  description: SITE_CONFIG.description,
  author: { '@type': 'Person', name: SITE_CONFIG.author.name, url: SITE_CONFIG.author.url },
}
---

<BaseLayout
  title="oriz / blog"
  description={SITE_CONFIG.description}
  jsonLd={jsonLd}
>
  <div class="container-page">
    {/* Lede — one line, no hero. */}
    <section class="lede-section">
      <p class="lede-line">
        An engineer's working notebook. <span class="count">{allPosts.length}</span> posts since 2019.
      </p>
      {inProgress[0] && (
        <p class="lede-spine">
          <SeriesSpine
            total={inProgress[0].total}
            published={inProgress[0].published}
            current={inProgress[0].current}
            size="md"
          />
        </p>
      )}
    </section>

    <hr class="hairline" />

    {/* Stratum 1 — IN PROGRESS. */}
    {inProgress.length > 0 && (
      <section class="stratum stratum-progress" aria-labelledby="s-progress">
        <h2 id="s-progress" class="stratum-h mono">In progress</h2>
        <ul class="progress-list">
          {inProgress.map((s) => (
            <li class="progress-row">
              <a class="progress-link" href={`/series/${s.slug}/`}>
                <span class="progress-name">{s.name}</span>
                <span class="progress-meta mono">part {s.published} of {s.total}</span>
                <span class="progress-spine-mount">
                  <SeriesSpine
                    total={s.total}
                    published={s.published}
                    current={s.current}
                    size="md"
                  />
                </span>
                <span class="progress-ago mono">{ago(s.latest)}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <hr class="hairline" />

    {/* Stratum 2 — RECENT. */}
    <section class="stratum stratum-recent" aria-labelledby="s-recent">
      <h2 id="s-recent" class="stratum-h mono">Recent</h2>
      <ul class="recent-list">
        {recentPosts.map((p) => (
          <li class="recent-row">
            <a class="recent-link" href={`/blog/${p.id}`}>
              <time class="recent-date mono" datetime={p.data.pubDate.toISOString()}>
                {p.data.pubDate.toISOString().slice(0, 10)}
              </time>
              <span class="recent-meat">
                <span class="recent-title">{p.data.title}</span>
                <span class="recent-dek">{p.data.description}</span>
              </span>
              <span class="recent-rt mono">{p.data.readingTime ?? readingTimeFor(p)}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="all-link">
        <a href="/archive/">all {allPosts.length} posts in the archive →</a>
      </p>
    </section>

    <hr class="hairline" />

    {/* Stratum 3 — BY CATEGORY (single typographic row). */}
    {cats.length > 0 && (
      <section class="stratum stratum-cats" aria-labelledby="s-cats">
        <h2 id="s-cats" class="stratum-h mono">By category</h2>
        <p class="cats-row">
          {cats.map((c, i) => (
            <>
              {i > 0 && <span class="cats-dot" aria-hidden="true">·</span>}
              <a href={`/categories/${slugifyTag(c.category)}/`} class="cats-link">
                <span class="cats-name">{c.category}</span>
                <span class="cats-count mono">({c.count})</span>
              </a>
            </>
          ))}
        </p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .container-page {
    max-width: 920px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2rem);
  }

  /* ── Lede ─────────────────────────────────────────────────────────── */

  .lede-section {
    padding-block: clamp(2.5rem, 6vw, 4rem) 1.75rem;
  }
  .lede-line {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 400;
    line-height: 1.4;
    color: var(--ink);
    margin: 0;
    max-width: 36ch;
  }
  .lede-line .count {
    font-family: var(--font-mono);
    font-variation-settings: normal;
    font-size: 0.85em;
    color: var(--cobalt);
  }
  .lede-spine { margin: 1rem 0 0; }

  /* ── Strata ────────────────────────────────────────────────────────── */

  .stratum { padding-block: 1.75rem 1.75rem; }
  .stratum-h {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-mute);
    font-weight: 500;
    margin: 0 0 1.25rem;
  }

  /* ── In progress ──────────────────────────────────────────────────── */

  .progress-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .progress-row { padding: 0; }
  .progress-link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto auto;
    gap: 1rem;
    align-items: baseline;
    color: var(--ink);
    text-decoration: none;
    padding-block: 0.5rem;
  }
  .progress-link:hover { color: var(--cobalt); }
  .progress-link:hover .progress-meta,
  .progress-link:hover .progress-ago { color: var(--cobalt); }
  .progress-name {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'SOFT' 30;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .progress-meta, .progress-ago {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-mute);
  }
  .progress-spine-mount { display: inline-flex; }

  @media (max-width: 640px) {
    .progress-link {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        'name      ago'
        'meta      meta'
        'spine     spine';
      row-gap: 0.25rem;
    }
    .progress-name { grid-area: name; }
    .progress-meta { grid-area: meta; }
    .progress-spine-mount { grid-area: spine; }
    .progress-ago { grid-area: ago; text-align: right; }
  }

  /* ── Recent ───────────────────────────────────────────────────────── */

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .recent-row {
    border-bottom: 1px solid color-mix(in oklab, var(--rule) 70%, transparent);
  }
  .recent-row:last-child { border-bottom: 0; }
  .recent-link {
    display: grid;
    grid-template-columns: 100px minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: baseline;
    color: var(--ink);
    text-decoration: none;
    padding-block: 0.875rem;
  }
  .recent-link:hover .recent-title { color: var(--cobalt); }
  .recent-link:hover .recent-date,
  .recent-link:hover .recent-rt { color: var(--cobalt); }

  .recent-date {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .recent-meat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }
  .recent-title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'SOFT' 30;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }
  .recent-dek {
    font-family: var(--font-serif);
    font-size: 14.5px;
    color: var(--ink-mute);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }
  .recent-rt {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .recent-link {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        'date   rt'
        'meat   meat';
      row-gap: 0.25rem;
    }
    .recent-date { grid-area: date; }
    .recent-rt { grid-area: rt; text-align: right; }
    .recent-meat { grid-area: meat; }
  }

  .all-link {
    margin: 1.25rem 0 0;
    font-family: var(--font-sans);
    font-size: 13.6px;
  }
  .all-link a {
    color: var(--ink-mute);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .all-link a:hover { color: var(--cobalt); text-decoration-color: var(--cobalt); }

  /* ── By category (one row) ────────────────────────────────────────── */

  .cats-row {
    margin: 0;
    line-height: 2;
    color: var(--ink);
  }
  .cats-link {
    color: var(--ink);
    text-decoration: none;
    margin-inline: 0.125rem;
  }
  .cats-link:hover .cats-name { color: var(--cobalt); }
  .cats-name {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24, 'SOFT' 30;
    font-size: 17px;
    font-weight: 400;
  }
  .cats-count {
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    margin-left: 0.25rem;
  }
  .cats-dot { color: var(--rule); margin-inline: 0.625rem; }
</style>
