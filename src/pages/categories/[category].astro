---
import { getCollection } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import PostCard from '~/components/blog/PostCard.astro'
import { getPostCategories, slugifyTag } from '~/lib/blog'

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const byCat = new Map<string, { label: string; posts: typeof allPosts }>()
  for (const post of allPosts) {
    for (const cat of getPostCategories(post)) {
      const slug = slugifyTag(cat)
      if (!slug) continue
      const existing = byCat.get(slug)
      if (existing) {
        if (!existing.posts.includes(post)) existing.posts.push(post)
      } else {
        byCat.set(slug, { label: cat, posts: [post] })
      }
    }
  }
  return [...byCat.entries()].map(([slug, { label, posts }]) => ({
    params: { category: slug },
    props: { category: label, posts },
  }))
}

const { category, posts } = Astro.props
const sortedPosts = [...posts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
---

<BaseLayout title={`Category: ${category} — Blog`} description={`Posts in the ${category} category.`}>
  <div class="page">
    <header class="page-head">
      <p class="eyebrow"><a href="/categories/">All categories</a></p>
      <h1>{category}</h1>
      <p class="meta">{sortedPosts.length} post{sortedPosts.length !== 1 ? 's' : ''}</p>
    </header>

    <ul class="post-grid">
      {sortedPosts.map((post) => (
        <li><PostCard post={post} /></li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { padding-block: 2.5rem 4rem; }
  .page-head { margin-bottom: 1.5rem; }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  .eyebrow a:hover { color: var(--color-fg); }
  h1 { font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-muted); font-size: 0.9375rem; margin: 0.5rem 0 0; }
  .post-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
