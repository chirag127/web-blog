---
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const tagsMap = new Map<string, { originalTag: string; posts: typeof allPosts }>()

  for (const post of allPosts) {
    if (post.data.tags) {
      for (const tag of post.data.tags) {
        const slug = tag.toLowerCase().replace(/\//g, '-').replace(/\s+/g, '-')
        if (!tagsMap.has(slug)) {
          tagsMap.set(slug, { originalTag: tag, posts: [] })
        }
        const group = tagsMap.get(slug)
        if (group && !group.posts.includes(post)) {
          group.posts.push(post)
        }
      }
    }
  }

  return [...tagsMap.entries()].map(([slug, { originalTag, posts }]) => ({
    params: { tag: slug },
    props: { tag: originalTag, posts },
  }))
}

const { tag, posts } = Astro.props
const _sortedPosts = [...posts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<BaseLayout title={`#${tag} — Blog`} description={`Posts tagged with #${tag}.`}>
  <div class="page">
    <header class="page-head">
      <p class="eyebrow"><a href="/tags/">All tags</a></p>
      <h1>#{tag}</h1>
      <p class="meta">{sortedPosts.length} post{sortedPosts.length !== 1 ? 's' : ''}</p>
    </header>

    <ul class="post-grid">
      {sortedPosts.map((post) => (
        <li><PostCard post={post} /></li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { padding-block: 2.5rem 4rem; }
  .page-head { margin-bottom: 1.5rem; }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  .eyebrow a:hover { color: var(--color-fg); }
  h1 { font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .meta { color: var(--color-fg-muted); font-size: 0.9375rem; margin: 0.5rem 0 0; }
  .post-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
