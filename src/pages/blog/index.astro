---
/**
 * /blog — page 1 of the paginated blog index.
 * Pages 2+ live at /blog/page/[page] (see ./page/[page].astro).
 *
 * Layout: filter chip strip of every category, then a 12-card grid.
 */
import BaseLayout from '~/components/layout/BaseLayout.astro'
import PostCard from '~/components/blog/PostCard.astro'
import {
  getAllCategories,
  getPublishedPosts,
  slugifyTag,
} from '~/lib/blog'
import { SITE_CONFIG } from '~/lib/config'

const PAGE_SIZE = 12

const allPosts = await getPublishedPosts()
const categories = await getAllCategories()
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE))
const posts = allPosts.slice(0, PAGE_SIZE)

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `Blog — ${SITE_CONFIG.title}`,
  url: new URL('/blog/', SITE_CONFIG.url).toString(),
  description:
    'Writing on software, AI agents, finance tooling, and the tools I build at oriz.in.',
  author: {
    '@type': 'Person',
    name: SITE_CONFIG.author.name,
    url: SITE_CONFIG.author.url,
  },
}
---

<BaseLayout
  title="Blog"
  description="Writing on software, AI agents, finance tooling, and the tools I build."
  jsonLd={jsonLd}
>
  <div class="container-page section">
    <header class="blog-head">
      <h1>Blog</h1>
      <p class="blog-lede">
        Writing on software, AI agents, finance tooling, and the tools I build.
      </p>
    </header>

    {categories.length > 0 && (
      <nav class="chip-strip" aria-label="Filter posts by category">
        <a class="chip is-active" href="/blog/">All</a>
        {categories.map((c) => (
          <a class="chip" href={`/categories/${slugifyTag(c)}/`}>{c}</a>
        ))}
      </nav>
    )}

    {posts.length === 0 ? (
      <p class="muted">No posts yet — the first one drops shortly.</p>
    ) : (
      <ul class="post-grid">
        {posts.map((p) => (
          <li>
            <PostCard post={p} />
          </li>
        ))}
      </ul>
    )}

    {totalPages > 1 && (
      <nav class="pager" aria-label="Pagination">
        <span class="pager-info">Page 1 of {totalPages}</span>
        <a class="pager-link" href="/blog/page/2/" rel="next">Next →</a>
      </nav>
    )}
  </div>
</BaseLayout>

<style>
  .blog-head {
    margin-bottom: 1.5rem;
  }
  .blog-head h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .blog-lede {
    color: var(--color-fg-muted);
    margin: 0.5rem 0 0;
    max-width: 60ch;
  }
  .chip-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .chip {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .chip:hover {
    color: var(--color-fg);
    border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border));
  }
  .chip.is-active {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-color: var(--color-accent);
  }
  .post-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .pager {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .pager-info {
    color: var(--color-fg-muted);
    font-size: 0.875rem;
  }
  .pager-link {
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--color-fg);
    background: var(--color-bg-soft);
  }
  .pager-link:hover {
    border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border));
  }
  .muted { color: var(--color-fg-muted); }
  .section { padding-block: 3rem; }
</style>
