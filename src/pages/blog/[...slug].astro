---
/**
 * /blog/[slug] — single blog post.
 * Renders the MDX body inside `.prose-oriz .container-prose`, plus
 * TOC, share buttons, series nav, related posts, lazy giscus, and
 * a Firestore-backed bookmark button.
 *
 * Pagefind picks up the post body via `data-pagefind-body` on the article
 * wrapper; metadata via `data-pagefind-meta="…"` attributes.
 */
import type { GetStaticPaths } from 'astro'
import { type CollectionEntry, render } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import GiscusComments from '~/components/blog/GiscusComments.astro'
import RelatedPosts from '~/components/blog/RelatedPosts.astro'
import SeriesNav from '~/components/blog/SeriesNav.astro'
import ShareButtons from '~/components/blog/ShareButtons.astro'
import TableOfContents from '~/components/blog/TableOfContents.astro'
import BookmarkButton from '~/components/blog/BookmarkButton.tsx'
import { formatPostDate, getPublishedPosts, readingTimeFor, slugifyTag } from '~/lib/blog'
import { SITE_CONFIG } from '~/lib/config'

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts()
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}) satisfies GetStaticPaths

interface PageProps {
  post: CollectionEntry<'blog'>
}
const { post } = Astro.props as PageProps
const { Content, headings } = await render(post)

const allPosts = await getPublishedPosts()
const seriesPosts = post.data.series
  ? allPosts.filter((p) => p.data.series === post.data.series)
  : []

const url = new URL(`/blog/${post.id}/`, SITE_CONFIG.url).toString()
const datePublished = post.data.pubDate.toISOString()
const dateModified = (post.data.updatedDate ?? post.data.pubDate).toISOString()
const rt = post.data.readingTime ?? readingTimeFor(post)

// Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished,
  dateModified,
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: SITE_CONFIG.author.url,
  },
  publisher: {
    '@type': 'Person',
    name: SITE_CONFIG.author.name,
    url: SITE_CONFIG.author.url,
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  inLanguage: SITE_CONFIG.defaultLocale,
  image: post.data.heroImage
    ? new URL(post.data.heroImage, SITE_CONFIG.url).toString()
    : undefined,
}

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: `${SITE_CONFIG.url}/` },
    {
      '@type': 'ListItem',
      position: 2,
      name: post.data.category,
      item: `${SITE_CONFIG.url}/categories/${slugifyTag(post.data.category)}/`,
    },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  canonical={post.data.canonical ?? url}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  image={post.data.heroImage}
  jsonLd={[articleSchema, breadcrumbSchema]}
  hideSidebar={true}
>
  <article
    class="post-shell"
    data-pagefind-body
    data-pagefind-meta={`category:${post.data.category}`}
    data-pagefind-filter={`category:${post.data.category},author:${post.data.author}${post.data.series ? `,series:${post.data.series}` : ''}`}
  >
    <div class="post-main">
      <header class="post-header">
        <p class="post-eyebrow">
          <a href={`/categories/${slugifyTag(post.data.category)}/`} data-pagefind-meta="category">
            {post.data.category}
          </a>
          <span aria-hidden="true">·</span>
          <span>{rt}</span>
        </p>
        <h1 class="post-title" transition:name={`title-${post.id}`}>{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-byline">
          <span>
            By <a href={`/authors/${slugifyTag(post.data.author)}/`} rel="author">
              {post.data.author}
            </a>
          </span>
          <span aria-hidden="true">·</span>
          <time datetime={datePublished}>{formatPostDate(post.data.pubDate)}</time>
          {post.data.updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated {formatPostDate(post.data.updatedDate)}</span>
            </>
          )}
          <span class="post-byline-spacer"></span>
          <BookmarkButton
            client:idle
            slug={post.id}
            url={url}
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            pubDate={datePublished}
          />
        </div>
      </header>

      {post.data.series && seriesPosts.length > 1 && (
        <div class="container-prose">
          <SeriesNav post={post} allInSeries={seriesPosts} />
        </div>
      )}

      <div class="post-body container-prose prose-oriz">
        <Content />
      </div>

      {post.data.tags.length > 0 && (
        <ul class="post-tags container-prose" aria-label="Tags">
          {post.data.tags.map((t) => (
            <li>
              <a class="post-tag" href={`/tags/${slugifyTag(t)}/`}>#{t}</a>
            </li>
          ))}
        </ul>
      )}

      <div class="post-share container-prose">
        <ShareButtons title={post.data.title} url={url} />
      </div>

      <div class="post-related container-prose">
        <RelatedPosts current={post} candidates={allPosts} />
      </div>

      <div class="post-comments container-prose">
        <GiscusComments />
      </div>
    </div>

    <aside class="post-aside" aria-label="Table of contents">
      <TableOfContents headings={headings} />
    </aside>
  </article>

  <script define:vars={{ slug: post.id, url, title: post.data.title }}>
    /** Push the post into recently-viewed (localStorage). */
    try {
      const KEY = 'oriz:blog:recent'
      const cur = JSON.parse(localStorage.getItem(KEY) ?? '[]')
      const filtered = cur.filter((r) => r.slug !== slug)
      filtered.unshift({ slug, url, title, visitedAt: new Date().toISOString() })
      localStorage.setItem(KEY, JSON.stringify(filtered.slice(0, 10)))
    } catch {}
  </script>
</BaseLayout>

<style>
  .post-shell {
    padding-block: 3rem;
    display: grid;
    gap: 2rem;
    max-width: var(--container-page, 1200px);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }
  .post-main { min-width: 0; }
  .post-header {
    max-width: var(--container-prose, 720px);
    margin-inline: auto;
    text-align: left;
  }
  .post-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-fg-muted);
    font-size: 0.8125rem;
    margin: 0 0 0.75rem;
  }
  .post-eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  .post-eyebrow a:hover { color: var(--color-fg); }
  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 0.75rem;
    color: var(--color-fg);
  }
  .post-desc {
    color: var(--color-fg-muted);
    font-size: 1.0625rem;
    margin: 0 0 1rem;
    max-width: 60ch;
  }
  .post-byline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    color: var(--color-fg-soft);
    font-size: 0.875rem;
    margin: 0 0 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .post-byline a { color: var(--color-fg-muted); text-decoration: none; }
  .post-byline a:hover { color: var(--color-fg); }
  .post-byline-spacer { flex: 1; }
  .post-body { margin-top: 2rem; }
  .post-tags {
    list-style: none;
    margin: 2.5rem auto 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .post-tag {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .post-tag:hover {
    color: var(--color-fg);
    border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border));
  }
  .post-share { margin-top: 2rem; }
  .post-related,
  .post-comments { margin-top: 2rem; }

  .post-aside { display: none; }

  @media (min-width: 1024px) {
    .post-shell {
      grid-template-columns: minmax(0, 1fr) 240px;
      align-items: start;
      gap: 3rem;
    }
    .post-aside {
      display: block;
      padding-top: 6rem;
      position: sticky;
      top: 80px;
    }
  }
</style>
