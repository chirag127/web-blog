---
/**
 * /blog/[slug] — single blog post (v2 design, 3-column re-grilled 2026-06-22).
 *
 * Responsive layout:
 *   - Mobile/tablet <1024px: single-column content + floating bottom-right
 *     "Contents" FAB that opens a vaul bottom-sheet TOC drawer.
 *   - Tablet/laptop ≥1024px: 2-col (content max-width 720px + right sticky
 *     TOC rail, 240px). Global Sidebar suppressed via hideSidebar on
 *     BaseLayout. Left post-sidebar still hidden at this breakpoint.
 *   - Desktop ≥1280px: 3-col (left collapsible BlogPostLeftSidebar + content
 *     + right TOC). Left default OPEN; hamburger toggles + persists.
 *
 * In-series extras:
 *   - Series jump-list (SeriesJumpList) at the bottom of the post body,
 *     above SeriesNav prev/next.
 *   - Series jump-list ALSO rendered inside BlogPostLeftSidebar.
 *
 * Series spine: inline in the meta row + in the right rail on desktop.
 * Drop-cap: Source Serif 4 cobalt rust, first paragraph (in blog-prose.css).
 */
import type { GetStaticPaths } from 'astro'
import { type CollectionEntry, render } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import GiscusComments from '~/components/blog/GiscusComments.astro'
import SeriesNav from '~/components/blog/SeriesNav.astro'
import SeriesSpine from '~/components/SeriesSpine.astro'
import TableOfContents from '~/components/blog/TableOfContents.astro'
import MobileTocDrawer from '~/components/MobileTocDrawer.tsx'
import BookmarkButton from '~/components/blog/BookmarkButton.tsx'
import BlogPostLeftSidebar from '~/components/blog/BlogPostLeftSidebar.astro'
import SeriesJumpList from '~/components/blog/SeriesJumpList.astro'
import {
  formatPostDate,
  getPostsInSeries,
  getPublishedPosts,
  readingTimeFor,
  slugifyTag,
} from '~/lib/blog'
import { SITE_CONFIG } from '~/lib/config'
import '~/styles/blog-prose.css'

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts()
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}) satisfies GetStaticPaths

interface PageProps {
  post: CollectionEntry<'blog'>
}
const { post } = Astro.props as PageProps
const { Content, headings } = await render(post)

const allPosts = await getPublishedPosts()

// Series spine data — only when this post is in a series.
let seriesPosts: typeof allPosts = []
let seriesPublished = 0
let seriesTotal = 0
let seriesCurrent = 0
if (post.data.series) {
  seriesPosts = await getPostsInSeries(post.data.series)
  seriesPublished = seriesPosts.length
  // Where this post sits in the published sequence (1-based).
  const idx = seriesPosts.findIndex((p) => p.id === post.id)
  seriesCurrent = idx >= 0 ? idx + 1 : seriesPublished
  // Heuristic for the "drafting" tail.
  const explicitMax = seriesPosts.reduce((mx, p) => {
    const v = typeof p.data.part === 'number' ? p.data.part : Number(p.data.part)
    return Number.isFinite(v) ? Math.max(mx, v) : mx
  }, 0)
  seriesTotal = Math.min(12, Math.max(seriesPublished + 2, explicitMax))
}

const url = new URL(`/blog/${post.id}/`, SITE_CONFIG.url).toString()
const datePublished = post.data.pubDate.toISOString()
const dateModified = (post.data.updatedDate ?? post.data.pubDate).toISOString()
const rt = post.data.readingTime ?? readingTimeFor(post)

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished,
  dateModified,
  author: { '@type': 'Person', name: post.data.author, url: SITE_CONFIG.author.url },
  publisher: { '@type': 'Person', name: SITE_CONFIG.author.name, url: SITE_CONFIG.author.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  inLanguage: SITE_CONFIG.defaultLocale,
  image: post.data.heroImage
    ? new URL(post.data.heroImage, SITE_CONFIG.url).toString()
    : undefined,
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: `${SITE_CONFIG.url}/` },
    {
      '@type': 'ListItem',
      position: 2,
      name: post.data.category,
      item: `${SITE_CONFIG.url}/categories/${slugifyTag(post.data.category)}/`,
    },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  canonical={post.data.canonical ?? url}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  image={post.data.heroImage}
  jsonLd={[articleSchema, breadcrumbSchema]}
  hideSidebar={true}
>
  <article
    class="post-shell"
    data-pagefind-body
    data-pagefind-meta={`category:${post.data.category}`}
    data-pagefind-filter={`category:${post.data.category},author:${post.data.author}${post.data.series ? `,series:${post.data.series}` : ''}`}
  >
    <header class="post-header">
      <p class="post-meta mono">
        <a href={`/categories/${slugifyTag(post.data.category)}/`} data-pagefind-meta="category">
          {post.data.category}
        </a>
        <span class="dot" aria-hidden="true">·</span>
        <time datetime={datePublished}>{formatPostDate(post.data.pubDate)}</time>
        <span class="dot" aria-hidden="true">·</span>
        <span>{rt}</span>
        {post.data.series && seriesTotal > 0 && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span class="post-meta-spine">
              <SeriesSpine
                total={seriesTotal}
                published={seriesPublished}
                current={seriesCurrent}
                size="md"
              />
            </span>
          </>
        )}
      </p>
      <h1 class="post-title" transition:name={`title-${post.id}`}>{post.data.title}</h1>
      {post.data.description && (
        <p class="post-dek">{post.data.description}</p>
      )}
      <div class="post-byline">
        <span>
          By <a href={`/authors/${slugifyTag(post.data.author)}/`} rel="author">
            {post.data.author}
          </a>
        </span>
        {post.data.updatedDate && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span>Updated {formatPostDate(post.data.updatedDate)}</span>
          </>
        )}
        <span class="post-byline-spacer"></span>
        <BookmarkButton
          client:idle
          slug={post.id}
          url={url}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={datePublished}
        />
      </div>
    </header>

    <div class="post-grid" data-lsb-grid>
      <aside class="post-lsb" data-lsb aria-label="Post sidebar">
        <button
          type="button"
          class="lsb-toggle"
          aria-label="Toggle sidebar"
          aria-expanded="true"
          data-lsb-toggle
        >
          <span class="lsb-toggle-icon" aria-hidden="true">≡</span>
          <span class="lsb-toggle-label">Sidebar</span>
        </button>
        <div class="lsb-panel" data-lsb-panel>
          <BlogPostLeftSidebar post={post} />
        </div>
      </aside>

      <div class="post-main">
        {post.data.series && seriesPosts.length > 1 && (
          <SeriesNav post={post} allInSeries={seriesPosts} />
        )}

        <div class="post-body prose-blog">
          <Content />
        </div>

        {post.data.tags.length > 0 && (
          <ul class="post-tags" aria-label="Tags">
            {post.data.tags.map((t) => (
              <li>
                <a class="post-tag" href={`/tags/${slugifyTag(t)}/`}>#{t}</a>
              </li>
            ))}
          </ul>
        )}

        {post.data.series && seriesPosts.length > 1 && (
          <SeriesJumpList current={post} allInSeries={seriesPosts} />
        )}

        <div class="post-comments">
          <GiscusComments />
        </div>
      </div>

      <aside class="post-rail" aria-label="On this page">
        <div class="rail-sticky">
          {post.data.series && seriesTotal > 0 && (
            <div class="rail-spine">
              <p class="rail-h mono">{post.data.series}</p>
              <SeriesSpine
                total={seriesTotal}
                published={seriesPublished}
                current={seriesCurrent}
                size="md"
                orientation="vertical"
                ariaLabel={`Series progress: part ${seriesCurrent} of ${seriesTotal}`}
              />
            </div>
          )}
          <nav class="rail-toc" aria-label="On this page (desktop)">
            <p class="rail-h mono">On this page</p>
            <TableOfContents headings={headings} />
          </nav>
        </div>
      </aside>
    </div>
  </article>

  <MobileTocDrawer
    client:idle
    items={headings
      .filter((h) => h.depth === 2 || h.depth === 3)
      .map((h) => ({ slug: h.slug, text: h.text, depth: h.depth }))}
  />

  <script define:vars={{ slug: post.id, url, title: post.data.title }}>
    /** Push the post into recently-viewed (localStorage). */
    try {
      const KEY = 'oriz:blog:recent'
      const cur = JSON.parse(localStorage.getItem(KEY) ?? '[]')
      const filtered = cur.filter((r) => r.slug !== slug)
      filtered.unshift({ slug, url, title, visitedAt: new Date().toISOString() })
      localStorage.setItem(KEY, JSON.stringify(filtered.slice(0, 10)))
    } catch {}
  </script>

  <script is:inline>
    /** Left-sidebar hamburger toggle.
     *  Default open ≥1280px (handled in CSS), user state persisted in
     *  localStorage('oriz:blog:lsb') so it survives navigations. */
    function initLsb() {
      const wrap = document.querySelector('[data-lsb]')
      const toggle = document.querySelector('[data-lsb-toggle]')
      if (!wrap || !toggle) return
      const KEY = 'oriz:blog:lsb'
      const stored = localStorage.getItem(KEY)
      const initialOpen = stored == null ? true : stored === '1'
      const apply = function (open) {
        wrap.dataset.open = open ? '1' : '0'
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false')
      }
      apply(initialOpen)
      toggle.addEventListener('click', function () {
        const open = wrap.dataset.open !== '1'
        apply(open)
        localStorage.setItem(KEY, open ? '1' : '0')
      })
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLsb)
    } else {
      initLsb()
    }
    document.addEventListener('astro:page-load', initLsb)
  </script>
</BaseLayout>

<style>
  /* ── Shell ─────────────────────────────────────────────────────────────
     Hero/header full-width above; then a 2-col grid (content + right TOC
     rail) on desktop, single-column on mobile. The mobile FAB + vaul
     drawer (rendered as a React island) takes over for navigation. */
  .post-shell {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    padding-block: 2.5rem 4rem;
  }

  /* Header sits above the grid; constrained to a comfortable measure. */
  .post-header {
    max-width: 720px;
    margin-inline: auto;
    text-align: left;
    margin-bottom: 2rem;
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  .post-main {
    min-width: 0;
    max-width: 720px;
    margin-inline: auto;
    width: 100%;
  }

  .post-rail { display: none; }
  .post-lsb { display: none; }

  /* ≥1024px: 2-col (content + right TOC). Left sidebar hidden at this
     breakpoint; user gets it back at ≥1280px (default-open). */
  @media (min-width: 1024px) {
    .post-grid {
      grid-template-columns: minmax(0, 720px) 240px;
      gap: 2rem;
      justify-content: center;
    }
    .post-main { margin-inline: 0; }
    .post-rail { display: block; }
    .rail-sticky {
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
      padding-top: 0.25rem;
    }
  }

  /* ≥1280px: 3-col with left collapsible sidebar default OPEN. */
  @media (min-width: 1280px) {
    .post-grid {
      grid-template-columns: 240px minmax(0, 720px) 240px;
      gap: 2.5rem;
      justify-content: center;
    }
    .post-lsb {
      display: block;
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
      align-self: start;
    }
    /* When user collapses, shrink to just the toggle button. */
    .post-grid:has([data-lsb][data-open='0']) {
      grid-template-columns: 56px minmax(0, 720px) 240px;
    }
  }

  /* Sidebar toggle + collapsible panel. */
  .lsb-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .lsb-toggle:hover { border-color: var(--cobalt); color: var(--cobalt); }
  .lsb-toggle-icon { font-size: 14px; line-height: 1; }
  .lsb-panel {
    overflow: hidden;
    transition: max-height 240ms ease, opacity 200ms ease;
    max-height: 5000px;
    opacity: 1;
  }
  .post-lsb[data-open='0'] .lsb-panel {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }
  .post-lsb[data-open='0'] .lsb-toggle-label { display: none; }

  .rail-h {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    margin: 0 0 0.625rem;
  }
  .rail-spine {
    margin-bottom: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .rail-toc :global(nav) {
    font-size: 13px;
    color: var(--ink-mute);
    line-height: 1.45;
  }
  .rail-toc :global(a) {
    color: var(--ink-mute);
    text-decoration: none;
    display: block;
    padding-block: 0.25rem;
  }
  .rail-toc :global(a:hover) { color: var(--cobalt); }

  /* ── Post header ──────────────────────────────────────────────────── */

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  .post-meta a { color: var(--ink-mute); text-decoration: none; }
  .post-meta a:hover { color: var(--cobalt); }
  .post-meta .dot { color: var(--rule); }
  .post-meta-spine { display: inline-flex; align-items: baseline; }

  .post-title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 96, 'SOFT' 50, 'wght' 380;
    font-size: clamp(2rem, 4.6vw, 41.5px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
    color: var(--ink);
  }
  .post-dek {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-mute);
    margin: 0 0 1.25rem;
    max-width: 60ch;
  }
  .post-byline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    color: var(--ink-mute);
    font-family: var(--font-sans);
    font-size: 13.6px;
    margin: 0 0 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .post-byline a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }
  .post-byline a:hover { color: var(--cobalt); text-decoration-color: var(--cobalt); }
  .post-byline-spacer { flex: 1; }
  .post-byline .dot { color: var(--rule); }

  .post-body { margin-top: 1.5rem; }

  .post-tags {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .post-tag {
    display: inline-block;
    padding: 0.125rem 0.625rem;
    border: 1px solid var(--rule);
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 12px;
    text-decoration: none;
  }
  .post-tag:hover { color: var(--cobalt); border-color: var(--cobalt); }

  .post-comments {
    margin-top: 3rem;
  }
</style>

<style is:global>
  /* ── Mobile TOC drawer (vaul) ──────────────────────────────────────── */

  .mtd-fab {
    position: fixed;
    right: 24px;
    bottom: calc(24px + env(safe-area-inset-bottom, 0px) + 56px); /* clear BottomBar */
    z-index: 40;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--color-accent);
    color: var(--paper);
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 180ms ease, transform 180ms ease;
    pointer-events: none;
  }
  .mtd-fab.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .mtd-fab:hover { filter: brightness(1.05); }
  .mtd-fab:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 2px;
  }

  @media (min-width: 1024px) {
    .mtd-fab { display: none !important; }
  }

  .mtd-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgba(15, 20, 25, 0.4);
  }
  .mtd-sheet {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 61;
    max-height: 80vh;
    overflow-y: auto;
    padding: 16px 20px calc(24px + env(safe-area-inset-bottom, 0px));
    background: var(--paper);
    border-top: 1px solid var(--rule);
    border-radius: 16px 16px 0 0;
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.18);
    outline: none;
  }
  .mtd-handle {
    width: 40px;
    height: 4px;
    background: var(--rule);
    border-radius: 2px;
    margin: 0 auto 12px;
  }
  .mtd-title {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 0.25rem;
  }
  .mtd-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-mute);
    margin: 0 0 0.75rem;
  }
  .mtd-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--rule);
  }
  .mtd-item { margin: 0; }
  .mtd-item button {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: 0;
    border-left: 2px solid transparent;
    margin-left: -1px;
    padding: 0.5rem 0.75rem;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.4;
    cursor: pointer;
  }
  .mtd-item button:hover {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
  .mtd-d3 button {
    padding-left: 1.5rem;
    font-size: 0.875rem;
    color: var(--ink-mute);
  }
</style>
