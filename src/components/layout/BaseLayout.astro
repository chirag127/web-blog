---
interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  image?: string
  type?: 'website' | 'article'
  pubDate?: Date
  updatedDate?: Date
  hideSidebar?: boolean
}

const _props = Astro.props as Props
---

<Base {...props}><slot /></Base>
