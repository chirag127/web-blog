---
const _categories = [
  { name: 'Engineering', slug: 'engineering' },
  { name: 'Finance', slug: 'finance' },
  { name: 'Books', slug: 'books' },
  { name: 'Personal', slug: 'personal' },
  { name: 'Notes', slug: 'notes' },
]
const _tags = ['astro', 'typescript', 'firebase', 'india', 'reading', 'agents']
const _series = [
  { name: 'Build the oriz family', slug: 'build-oriz' },
  { name: 'Reading log 2026', slug: 'reading-log-2026' },
]
---
<footer class="blog-footer" role="contentinfo">
  <div class="bf-quote">
    <blockquote>
      <span aria-hidden="true" class="bf-q-mark">“</span>
      Write the thing you'd Google for.
    </blockquote>
    <p class="bf-quote-attr">— blog · oriz</p>
  </div>
  <div class="bf-grid">
    <div class="bf-col">
      <h3 class="bf-h">Categories</h3>
      <ul>
        {categories.map((c) => <li><a href={`/blog/category/${c.slug}/`}>{c.name}</a></li>)}
      </ul>
    </div>
    <div class="bf-col">
      <h3 class="bf-h">Recent</h3>
      <ul>
        <li><a href="/blog/">Latest posts</a></li>
        <li><a href="/archive/">Archive</a></li>
        <li><a href="/posts/">All posts</a></li>
        <li><a href="/now/">Now</a></li>
      </ul>
    </div>
    <div class="bf-col">
      <h3 class="bf-h">Tags</h3>
      <ul class="bf-tags">
        {tags.map((t) => <li><a href={`/blog/tag/${t}/`}>#{t}</a></li>)}
      </ul>
    </div>
    <div class="bf-col">
      <h3 class="bf-h">Series</h3>
      <ul>
        {series.map((s) => <li><a href={`/series/${s.slug}/`}>{s.name}</a></li>)}
        <li><a href="/series/">All series</a></li>
      </ul>
    </div>
  </div>
  <LegalFooter
    appName="Oriz Blog"
    bio="Long-form writing on engineering, finance, and books by Chirag Singhal."
    rss="/rss.xml"
  />
</footer>
<style>
  .blog-footer {
    margin-top: 5rem;
    background: var(--color-paper-2, var(--paper-2, transparent));
    color: var(--color-ink, var(--ink));
    border-top: 1px solid var(--color-rule, var(--rule));
  }
  .bf-quote {
    max-width: 1200px; margin: 0 auto;
    padding: 40px 16px 24px;
    text-align: left;
  }
  .bf-quote blockquote {
    margin: 0;
    font-family: var(--font-display, 'Source Serif 4', Georgia, serif);
    font-style: italic; font-weight: 400; font-size: clamp(20px, 3vw, 28px);
    line-height: 1.35; color: var(--color-ink, var(--ink)); max-width: 540px;
  }
  .bf-q-mark { font-size: 1.6em; line-height: 0; color: var(--color-accent, var(--mustard, #c68e17)); margin-right: 4px; }
  .bf-quote-attr {
    margin: 14px 0 0; font-family: var(--font-mono, ui-monospace);
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--color-ink-mute, var(--ink-mute));
  }
  .bf-grid {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr; gap: 24px;
    padding: 12px 16px 24px;
  }
  .bf-h {
    margin: 0 0 12px;
    font-family: var(--font-mono, ui-monospace);
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--color-ink-mute, var(--ink-mute)); font-weight: 500;
  }
  .bf-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
  .bf-col a { color: var(--color-ink, var(--ink)); font-size: 14px; text-decoration: none; }
  .bf-col a:hover { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  .bf-tags { flex-direction: row; flex-wrap: wrap; gap: 8px 12px; }
  .bf-tags a { font-family: var(--font-mono, ui-monospace); font-size: 13px; color: var(--color-ink-mute, var(--ink-mute)); }
  .bf-tags a:hover { color: var(--color-accent, var(--mustard, #c68e17)); text-decoration: none; }
  @media (min-width: 768px) { .bf-grid { grid-template-columns: 1fr 1fr; gap: 32px; padding: 16px 24px 28px; } .bf-quote { padding: 56px 24px 20px; } }
  @media (min-width: 1024px) { .bf-grid { grid-template-columns: repeat(4, 1fr); padding: 16px 24px 32px; } }
</style>
