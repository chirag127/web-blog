---
import HeaderControls from '~/components/HeaderControls.tsx'
---

<header class="site-header" transition:persist="site-header">
  <div class="container-page header-inner">
    <a href="/" class="brand">
      <span class="brand-mark">oriz</span>
      <span class="brand-dot">.</span>
      <span class="brand-badge">Blog</span>
    </a>

    <nav aria-label="Primary" class="primary-nav">
      <a href="/blog/">Posts</a>
      <a href="/series/">Series</a>
      <a href="/categories/">Categories</a>
      <a href="/tags/">Tags</a>
      <a href="/archive/">Archive</a>
      <a href="/about/">About</a>
    </nav>

    <HeaderControls client:idle />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    height: 64px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.375rem;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-fg);
    line-height: 1;
  }
  .brand-dot { color: var(--color-accent); }
  .brand-badge {
    margin-left: 0.25rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--color-fg-muted);
  }
  .primary-nav {
    display: none;
    gap: 1.25rem;
    flex: 1;
    font-size: 0.9375rem;
  }
  .primary-nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .primary-nav a:hover { color: var(--color-fg); }
  @media (min-width: 768px) {
    .primary-nav { display: flex; }
  }
</style>
