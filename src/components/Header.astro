---
---

<StatusBanner />
<header class="site-header" transition:persist="site-header">
  <div class="container-page header-inner">
    <div class="brand">
      <Wordmark subtitle="blog" size={22} href="/" />
    </div>
    <nav class="header-nav" aria-label="Primary">
      <a href="/">Latest</a>
      <a href="/series/">Series</a>
      <a href="/tags/">Tags</a>
      <a href="/about/">About</a>
    </nav>
    <div class="header-multisearch">
      <MultiSearch client:idle />
    </div>
    <div class="header-controls-mount">
      <HeaderControls client:idle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--paper) 92%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--rule);
  }
  .header-inner {
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .brand {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    font-feature-settings: 'smcp' 1;
  }
  .header-nav {
    display: none;
    gap: 1.25rem;
    font-family: var(--font-utility, var(--font-mono));
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .header-nav a {
    position: relative;
    padding-block: 0.25rem;
    color: var(--color-muted);
    text-decoration: none;
    min-height: 32px;
    padding: 6px 0;
    display: inline-flex;
    align-items: center;
  }
  nav a {
    min-height: 32px;
    padding: 6px 0;
    display: inline-flex;
    align-items: center;
  }
  .header-nav a:hover {
    color: var(--color-fg);
  }
  .header-nav a:hover::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--color-accent);
  }
  @media (min-width: 768px) {
    .header-nav { display: inline-flex; align-items: center; }
  }
  .header-controls-mount {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
  }
  .header-multisearch {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
  }
  .header-multisearch + .header-controls-mount {
    margin-left: 0.75rem;
  }
</style>
