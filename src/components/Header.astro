---
/*
 * Header — 60px chrome bar (the v2 brief calls for 60px; we honor it).
 *
 * Layout:
 *   ┌─────────────────────────────────────────────────────────────────┐
 *   │  oriz / blog                              ⌘K · rss · ···        │
 *   └─────────────────────────────────────────────────────────────────┘
 *
 * Left:  Wordmark `oriz / blog` in Fraunces small caps.
 * Center: nothing (intentional).
 * Right: search trigger (⌘K, opens Pagefind in a centered modal),
 *        rss link, ··· overflow with /about /now /series + theme toggle.
 *
 * The brief specified 60px height; the heading "Header chrome (60px)"
 * overrides the brief's earlier "Single line at 64px". 60px wins.
 */
import Wordmark from '~/components/Wordmark.astro'
import HeaderControls from '~/components/HeaderControls.tsx'
---

<header class="site-header" transition:persist="site-header">
  <div class="container-page header-inner">
    <div class="brand">
      <Wordmark subtitle="blog" size={22} href="/" />
    </div>
    <div class="header-controls-mount">
      <HeaderControls client:idle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--paper) 92%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--rule);
  }
  .header-inner {
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .brand {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    font-feature-settings: 'smcp' 1;
  }
  .header-controls-mount {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
  }
</style>
