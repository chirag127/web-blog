---
/**
 * SiteSidebar — wraps the oriz-ui Sidebar React island with this site's
 * specific link sections. Browse / Read / Family. Hidden on legal/about/
 * contact/account pages via the `hideSidebar` prop on BaseLayout.
 */
import { Sidebar, FAMILY_SITES } from '@chirag127/oriz-ui'

const sections = [
  {
    title: 'Browse',
    links: [
      { label: 'All posts', href: '/blog/' },
      { label: 'Categories', href: '/categories/' },
      { label: 'Tags', href: '/tags/' },
      { label: 'Series', href: '/series/' },
      { label: 'Authors', href: '/authors/' },
      { label: 'Archive', href: '/archive/' },
    ],
  },
  {
    title: 'Read',
    links: [
      { label: 'Bookmarks', href: '/bookmarks/' },
      { label: 'Search', href: '/search/' },
      { label: 'RSS feed', href: '/rss.xml' },
    ],
  },
  {
    title: 'Family',
    links: FAMILY_SITES.map((s) => ({
      label: `${s.emoji} ${s.name}`,
      href: s.url,
    })),
  },
]
---

<Sidebar client:idle siteName="Blog" siteSlug="blog" sections={sections} />

<!-- Recently viewed (rendered in the same column as the Sidebar) -->
<aside class="recent" aria-labelledby="recent-h" id="recent-aside" hidden>
  <h3 id="recent-h" class="recent-h">Recently viewed</h3>
  <ul id="recent-list" class="recent-list"></ul>
</aside>

<script>
  /** Pull recently-viewed posts (localStorage) and render in the sidebar. */
  type Recent = { slug: string; url: string; title: string; visitedAt: string }
  try {
    const items: Recent[] = JSON.parse(localStorage.getItem('oriz:blog:recent') ?? '[]')
    const aside = document.getElementById('recent-aside') as HTMLElement | null
    const list = document.getElementById('recent-list') as HTMLUListElement | null
    if (items.length > 0 && aside && list) {
      aside.hidden = false
      list.innerHTML = items
        .slice(0, 5)
        .map(
          (it) =>
            `<li><a href="${it.url}">${it.title.replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' })[c] ?? c)}</a></li>`,
        )
        .join('')
    }
  } catch {}
</script>

<style>
  .recent {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .recent-h {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-soft);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }
  .recent-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; }
  .recent-list a {
    display: block;
    color: var(--color-fg-muted);
    font-size: 0.8125rem;
    text-decoration: none;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .recent-list a:hover { color: var(--color-fg); }
</style>
