---
// TODO: move to @chirag127/astro-chrome/embeds in v0.1.6
/**
 * <CodePlayground id="..." /> — StackBlitz embed.
 *
 * Lazy iframe pointing at https://stackblitz.com/edit/${id}?embed=1.
 */
interface Props {
  id: string
  title?: string
  height?: number
  /** Comma-separated panel list: e.g. "preview", "editor" */
  view?: 'preview' | 'editor' | 'both'
}
const { id, title = 'StackBlitz playground', height = 480, view = 'both' } = Astro.props as Props
const v = view === 'both' ? '' : `&view=${view}`
const _src = `https://stackblitz.com/edit/${id}?embed=1&hideExplorer=1&hideNavigation=1${v}`
---

<div class="cp-embed" style={`--cp-h: ${height}px`}>
  <iframe src={src} title={title} loading="lazy" allow="clipboard-write"></iframe>
</div>

<style>
  .cp-embed {
    position: relative;
    height: var(--cp-h, 480px);
    margin-block: 1.5rem;
    border-radius: var(--radius-card, 0.5rem);
    overflow: hidden;
    border: 1px solid var(--rule, #e4e1d8);
  }
  .cp-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
