---
/*
 * Wordmark — `oriz` set in display serif with a vermilion hairline strike
 * through the `z` glyph. The proofreader's deletion mark rendered as the
 * brand mark.
 *
 * Sister sites copy this component verbatim. On oriz-blog, the `subtitle`
 * is "blog" and the wordmark sits inside the 60px header chrome.
 *
 * Family-anchor file. See oriz-home/knowledge/anchor-patterns.md.
 */

interface Props {
  /** Sub-section name — rendered after a `/` separator. */
  subtitle?: string
  /** Display size in CSS pixels. */
  size?: number
  /** Wrap the mark in an <a href="/"> — defaults to '/' when subtitle is set. */
  href?: string | null
  /** Render as <h1> (the masthead) rather than <div>. */
  asHeading?: boolean
}

const { subtitle, size = 96, href = null, asHeading = false } = Astro.props
const Tag = asHeading ? 'h1' : ('div' as const)
---

{
  href ? (
    <a class="wordmark-link" href={href} aria-label={subtitle ? `oriz / ${subtitle}` : 'oriz'}>
      <Tag class="wordmark" style={`--wm-size: ${size}px;`}>
        <span class="wordmark-mark">
          <span class="wordmark-letter">o</span>
          <span class="wordmark-letter">r</span>
          <span class="wordmark-letter">i</span>
          <span class="wordmark-letter wordmark-z">
            z
            <span class="wordmark-strike" aria-hidden="true" />
          </span>
        </span>
        {subtitle && (
          <>
            <span class="wordmark-sep" aria-hidden="true">
              /
            </span>
            <span class="wordmark-sub">{subtitle}</span>
          </>
        )}
      </Tag>
    </a>
  ) : (
    <Tag class="wordmark" style={`--wm-size: ${size}px;`}>
      <span class="wordmark-mark">
        <span class="wordmark-letter">o</span>
        <span class="wordmark-letter">r</span>
        <span class="wordmark-letter">i</span>
        <span class="wordmark-letter wordmark-z">
          z
          <span class="wordmark-strike" aria-hidden="true" />
        </span>
      </span>
      {subtitle && (
        <>
          <span class="wordmark-sep" aria-hidden="true">
            /
          </span>
          <span class="wordmark-sub">{subtitle}</span>
        </>
      )}
    </Tag>
  )
}

<style>
  .wordmark-link {
    display: inline-block;
    color: inherit;
    text-decoration: none;
  }
  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-variation-settings: 'opsz' 60, 'SOFT' 30;
    font-size: var(--wm-size, 96px);
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--ink);
  }
  .wordmark-mark {
    display: inline-flex;
    align-items: baseline;
  }
  .wordmark-letter {
    position: relative;
    display: inline-block;
  }
  .wordmark-z {
    padding-inline: 0.15em;
  }
  .wordmark-strike {
    position: absolute;
    inset: 50% 0 auto 0;
    height: 0.04em;
    background: var(--vermilion);
    transform: translateY(-50%);
    pointer-events: none;
  }
  @media (max-width: 480px) {
    .wordmark-strike {
      height: max(1px, 0.04em);
    }
  }
  .wordmark-sep {
    margin-inline: 0.18em 0.18em;
    color: var(--ink-mute);
    font-weight: 400;
  }
  .wordmark-sub {
    color: var(--cobalt);
    font-style: italic;
    font-weight: 400;
  }
</style>
