---
/**
 * GiscusComments — consent-gated mount of the Giscus iframe.
 *
 * Per Batch-5 (Giscus = comments) + the consent decision: the iframe
 * does NOT load until the reader explicitly clicks "Load comments".
 * No third-party JS, no cookies, no GitHub-API calls happen until
 * consent is granted. Once granted, the click is remembered in
 * localStorage so the user isn't asked again on subsequent posts.
 *
 * The four IDs come from PUBLIC_GISCUS_* env vars resolved in
 * ~/lib/config. If repoId / categoryId are blank (e.g. dev), we
 * render an inline notice instead of a broken iframe.
 */
import { SITE_CONFIG } from '~/lib/config'

const g = SITE_CONFIG.giscus
const enabled = g.repoId.length > 0 && g.categoryId.length > 0
---

<section class="comments" aria-labelledby="comments-heading">
  <h2 id="comments-heading" class="comments-heading">Comments</h2>

  {enabled ? (
    <div
      id="giscus-mount"
      data-giscus-repo={g.repo}
      data-giscus-repo-id={g.repoId}
      data-giscus-category={g.category}
      data-giscus-category-id={g.categoryId}
      data-giscus-mapping={g.mapping}
      data-giscus-reactions={g.reactionsEnabled ? '1' : '0'}
      data-giscus-input-position={g.inputPosition}
    >
      <button id="giscus-consent" type="button" class="comments-consent">
        Load comments
        <span class="comments-consent-hint">
          Loads <a href="https://giscus.app">giscus</a> + a GitHub Discussions iframe.
        </span>
      </button>
    </div>
  ) : (
    <p class="comments-disabled">
      Comments are powered by <a href="https://giscus.app">giscus</a>. Set
      <code>PUBLIC_GISCUS_REPO_ID</code> and <code>PUBLIC_GISCUS_CATEGORY_ID</code> in your environment to enable them.
    </p>
  )}
</section>

<script>
  const CONSENT_KEY = 'oriz:blog:giscus-consent'
  const mount = document.getElementById('giscus-mount')
  if (mount) {
    const init = () => {
      if (mount.dataset.loaded === '1') return
      mount.dataset.loaded = '1'

      const script = document.createElement('script')
      script.src = 'https://giscus.app/client.js'
      script.async = true
      script.crossOrigin = 'anonymous'
      script.setAttribute('data-repo', mount.dataset.giscusRepo ?? '')
      script.setAttribute('data-repo-id', mount.dataset.giscusRepoId ?? '')
      script.setAttribute('data-category', mount.dataset.giscusCategory ?? '')
      script.setAttribute('data-category-id', mount.dataset.giscusCategoryId ?? '')
      script.setAttribute('data-mapping', mount.dataset.giscusMapping ?? 'pathname')
      script.setAttribute('data-strict', '0')
      script.setAttribute('data-reactions-enabled', mount.dataset.giscusReactions ?? '1')
      script.setAttribute('data-emit-metadata', '0')
      script.setAttribute('data-input-position', mount.dataset.giscusInputPosition ?? 'bottom')
      script.setAttribute(
        'data-theme',
        document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark_dimmed',
      )
      script.setAttribute('data-lang', 'en')
      script.setAttribute('data-loading', 'lazy')

      mount.replaceChildren(script)
    }

    const consentBtn = document.getElementById('giscus-consent')
    const grantConsent = () => {
      try {
        localStorage.setItem(CONSENT_KEY, '1')
      } catch {}
      init()
    }

    // If consent was previously granted (per the consent decision —
    // remember it so the user isn't asked on every post), auto-load.
    let alreadyConsented = false
    try {
      alreadyConsented = localStorage.getItem(CONSENT_KEY) === '1'
    } catch {}

    if (alreadyConsented) {
      init()
    } else if (consentBtn) {
      consentBtn.addEventListener('click', grantConsent)
    }
  }
</script>

<style>
  .comments { margin-top: 3rem; }
  .comments-heading {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .comments-placeholder { color: var(--color-fg-soft); font-size: 0.875rem; margin: 0; }
  .comments-consent {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0.625rem 1rem;
    background: var(--color-bg-soft, #f7f5f0);
    border: 1px solid var(--color-border, #ddd);
    border-radius: var(--radius-card, 0.5rem);
    color: var(--color-fg, #222);
    font: inherit;
    font-weight: 500;
    cursor: pointer;
  }
  .comments-consent:hover { border-color: var(--cobalt, #1f4ed8); color: var(--cobalt, #1f4ed8); }
  .comments-consent-hint {
    font-size: 0.75rem;
    color: var(--color-fg-muted, #666);
    font-weight: 400;
  }
  .comments-consent-hint a { color: inherit; text-decoration: underline; }
  .comments-disabled {
    padding: 1rem 1.25rem;
    background: var(--color-bg-soft);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-fg-muted);
    font-size: 0.875rem;
    margin: 0;
  }
  .comments-disabled code {
    padding: 0.0625rem 0.375rem;
    background: var(--color-bg-muted);
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
</style>
