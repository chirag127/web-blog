# ============================================================
# oriz-blog — environment variables (canonical superset)
#
# All vars are OPTIONAL at build time. Missing keys fall back to
# safe no-op behaviour (e.g. Algolia → client-side filter; Giscus
# → "configure giscus" notice; AdSense → no-op).
#
# Pulled from envpact in CI; locally via:
#   npx envpact-cli@0.2.0
# ============================================================

# ---- Firebase (shared via envpact 'shared' block) ----
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=auth.oriz.in
PUBLIC_FIREBASE_PROJECT_ID=oriz-app
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ---- Cloudflare ----
PUBLIC_CF_BEACON_TOKEN=
PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET=
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=

# ---- hCaptcha (alt to Turnstile) ----
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# ---- Newsletter / Mail ----
PUBLIC_BUTTONDOWN_USERNAME=chirag127
BUTTONDOWN_API_KEY=
EMAIL_OCTOPUS_API_KEY=
RESEND_API_KEY=
KNOCK_API_KEY=

# ---- Contact form ----
PUBLIC_WEB3FORMS_KEY=
WEB3FORMS_KEY=

# ---- Analytics ----
PUBLIC_GA4_ID=
GA4_MEASUREMENT_ID=
SENTRY_DSN=
ENABLE_SENTRY=
ENABLE_POSTHOG=
POSTHOG_KEY=
POSTHOG_HOST=

# ---- AdSense (uncomment ONLY after publisher approval) ----
# PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ---- Giscus comments (https://giscus.app) ----
PUBLIC_GISCUS_REPO=chirag127/oriz-blog
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=

# ---- Algolia (search-large-corpus pick — Batch 4 lock) ----
# When ALGOLIA_APP_ID is empty, <Search /> falls back to client-side filter.
PUBLIC_ALGOLIA_APP_ID=
PUBLIC_ALGOLIA_SEARCH_KEY=
PUBLIC_ALGOLIA_INDEX_NAME=oriz-blog
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=oriz-blog

# ---- Billing (forward-ref — oriz-blog has no paywall today) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
LEMON_SQUEEZY_API_KEY=
KEYGEN_ACCOUNT_ID=
KEYGEN_TOKEN=

# ---- Database (forward-ref) ----
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
NEON_DATABASE_URL=

# ---- Backups ----
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
RESTIC_PASSWORD=

# ---- CI / Secrets ----
GITHUB_TOKEN=
DOPPLER_TOKEN=

# ---- Monitoring ----
BETTER_STACK_API_KEY=
INSTATUS_API_KEY=

# ---- Cross-post (oriz-omnipost reads these on `pnpm omnipost:cross-post`) ----
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
DEV_TO_API_KEY=
WORDPRESS_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ---- Extension stores (n/a here — kept for canonical superset) ----
OPEN_VSX_TOKEN=
VSCE_PAT=
CHROME_WEBSTORE_CLIENT_ID=
CHROME_WEBSTORE_CLIENT_SECRET=
CHROME_WEBSTORE_REFRESH_TOKEN=
AMO_JWT_ISSUER=
AMO_JWT_SECRET=
EDGE_PARTNER_PRODUCT_ID=
EDGE_PARTNER_API_KEY=
EDGE_PARTNER_CLIENT_ID=

# ---- Misc ----
RAINDROP_TOKEN=
INDEXNOW_KEY=
GSC_VERIFICATION_TOKEN=
BING_VERIFICATION_TOKEN=
